{
  "name": "@oh-pen-testing/playbooks-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Bundled core playbooks shipped with oh-pen-testing.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "secrets",
    "owasp",
    "sca",
    "wstg",
    "cwe-top-25",
    "iac",
    "asvs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oh-Pen-Sauce/oh-pen-testing.git",
    "directory": "playbooks/core"
  },
  "homepage": "https://github.com/Oh-Pen-Sauce/oh-pen-testing#readme",
  "bugs": {
    "url": "https://github.com/Oh-Pen-Sauce/oh-pen-testing/issues"
  },
  "author": "Oh Pen Sauce",
  "engines": {
    "node": ">=22"
  }
}
