{
  "name": "@oh-pen-testing/web",
  "version": "1.0.2",
  "description": "Local setup wizard and dashboard for Oh Pen Testing. Shipped as a runtime dependency of @oh-pen-testing/cli — not intended to be installed directly.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -H 127.0.0.1 -p 7676",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 7676",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo",
    "prepublishOnly": "next build"
  },
  "files": [
    ".next",
    "public",
    "next.config.js",
    "next.config.mjs",
    "next.config.ts",
    "package.json"
  ],
  "dependencies": {
    "@oh-pen-testing/core": "workspace:*",
    "@oh-pen-testing/git-github": "workspace:*",
    "@oh-pen-testing/playbooks-core": "workspace:*",
    "@oh-pen-testing/providers-anthropic": "workspace:*",
    "@oh-pen-testing/providers-claude-code-cli": "workspace:*",
    "@oh-pen-testing/providers-ollama": "workspace:*",
    "@oh-pen-testing/rate-limit": "workspace:*",
    "@oh-pen-testing/shared": "workspace:*",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^1.24.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oh-Pen-Sauce/oh-pen-testing.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/Oh-Pen-Sauce/oh-pen-testing#readme",
  "bugs": {
    "url": "https://github.com/Oh-Pen-Sauce/oh-pen-testing/issues"
  },
  "author": "Oh Pen Sauce",
  "engines": {
    "node": ">=22"
  }
}
