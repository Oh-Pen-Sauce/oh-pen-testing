{
  "name": "@oh-pen-testing/cli",
  "version": "1.0.0",
  "description": "Local opensource pen-testing suite. Your code. Your AI. Your terms. `opt` is the CLI entry point.",
  "keywords": [
    "security",
    "pentesting",
    "penetration-testing",
    "sast",
    "owasp",
    "cwe",
    "sca",
    "ai",
    "claude",
    "vulnerability-scanner"
  ],
  "type": "module",
  "bin": {
    "oh-pen-testing": "./dist/index.js",
    "opt": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "@oh-pen-testing/core": "workspace:*",
    "@oh-pen-testing/git-github": "workspace:*",
    "@oh-pen-testing/playbooks-core": "workspace:*",
    "@oh-pen-testing/providers-anthropic": "workspace:*",
    "@oh-pen-testing/providers-claude-code-cli": "workspace:*",
    "@oh-pen-testing/providers-ollama": "workspace:*",
    "@oh-pen-testing/shared": "workspace:*",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "open": "^10.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oh-Pen-Sauce/oh-pen-testing.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Oh-Pen-Sauce/oh-pen-testing#readme",
  "bugs": {
    "url": "https://github.com/Oh-Pen-Sauce/oh-pen-testing/issues"
  },
  "author": "Oh Pen Sauce",
  "engines": {
    "node": ">=22"
  }
}
